<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ======================================================= -->
    <!-- 1. ACTIONS                                              -->
    <!-- ======================================================= -->

    <!-- Action: Students -->
    <record id="action_school_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">school.student</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first student!
            </p>
        </field>
    </record>


    <!-- ======================================================= -->
    <!-- 2. MAIN ROOT MENU                                       -->
    <!-- ======================================================= -->

    <menuitem id="menu_school_root"
              name="School"
              web_icon="school_management,static/description/icon.png"
              sequence="10"/>


    <!-- ======================================================= -->
    <!-- 3. TOP CATEGORIES & SUB-MENUS                           -->
    <!-- ======================================================= -->

    <menuitem id="menu_school_academic"
              name="Academic"
              parent="menu_school_root"
              sequence="10"/>

    <menuitem id="menu_school_student"
              name="Students"
              parent="menu_school_academic"
              action="action_school_student"
              sequence="10"/>

</odoo>