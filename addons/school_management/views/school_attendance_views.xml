<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Attendance List View -->
    <record id="school_attendance_tree_view" model="ir.ui.view">
        <field name="name">school.attendance.tree</field>
        <field name="model">school.attendance</field>
        <field name="arch" type="xml">
            <tree string="Attendance">
                <field name="student_id"/>
                <field name="class_id"/>
                <field name="date"/>
                <field name="status"/>
            </tree>
        </field>
    </record>


    <!-- Attendance Form View -->
    <record id="school_attendance_form_view" model="ir.ui.view">
        <field name="name">school.attendance.form</field>
        <field name="model">school.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance">
                <sheet>
                    <group>
                        <field name="student_id"/>
                        <field name="class_id"/>
                        <field name="date"/>
                        <field name="status"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <!-- Attendance Action -->
    <record id="action_school_attendance" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">school.attendance</field>
        <field name="view_mode">tree,form</field>
    </record>


</odoo>